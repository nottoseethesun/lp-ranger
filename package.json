{
  "name": "9mm-v3-position-manager",
  "version": "2.0.0",
  "description": "Auto-rebalancing position manager for 9mm v3 (Uniswap v3 fork) on PulseChain",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "bot": "node bot.js",
    "stop": "node -e \"const http=require('http');const r=http.request({hostname:'127.0.0.1',port:process.env.PORT||5555,path:'/api/shutdown',method:'POST'},s=>{let d='';s.on('data',c=>d+=c);s.on('end',()=>{console.log(d);process.exit(0)})});r.on('error',e=>{console.error('Server not running or unreachable:',e.message);process.exit(1)});r.end()\"",
    "check": "bash scripts/check.sh",
    "lint": "eslint src/ test/ server.js bot.js public/dashboard-*.js eslint-rules/ --max-warnings 0 && stylelint public/*.css",
    "lint:fix": "eslint src/ test/ server.js bot.js public/dashboard-*.js eslint-rules/ --fix && stylelint public/*.css --fix",
    "test": "node --test test/*.test.js test/eslint-rules/*.test.js",
    "test:coverage": "node --test --experimental-test-coverage test/*.test.js test/eslint-rules/*.test.js",
    "test:watch": "node --test --watch test/*.test.js test/eslint-rules/*.test.js",
    "knip": "knip"
  },
  "dependencies": {
    "dotenv": "^16.0.0",
    "ethers": "^6.7.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "globals": "^17.4.0",
    "knip": "^5.86.0",
    "stylelint": "^17.4.0",
    "stylelint-config-standard": "^40.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "Apache-2.0"
}
