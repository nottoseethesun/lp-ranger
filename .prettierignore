# Files Prettier should not check or rewrite.
#
# `prettier --check '**/*.json'` is wired into `npm run lint` and
# `npm run check` (scripts/check.js). Anything listed here is skipped by
# every Prettier invocation. Each entry below explains why it is excluded.

# Lockfile — npm owns the format. Reformatting causes spurious diffs,
# merge conflicts, and can break `npm ci` integrity checks.
package-lock.json

# Build output — regenerated by `npm run build` from authored sources.
# Linting generated files would either churn on every build or block
# builds when an upstream tool's output drifts from Prettier's style.
src/build-info.json

# Test/run artifacts — recreated on every `npm run check`; never
# committed; not human-authored.
tmp/
test/report-artifacts/

# Runtime state files written by the running app (encrypted wallet,
# bot-config, rebalance log, API keys). Gitignored, machine-generated,
# user-secret-bearing, and shape-volatile — must not be normalized.
# The tracked format template is `app-config/api-keys.example.json`,
# which IS linted (it's not in this ignore list).
app-config/.bot-config.json
app-config/.bot-config.backup.json
app-config/.bot-config.v1.json
app-config/.wallet.json
app-config/api-keys.json
app-config/rebalance_log.json
