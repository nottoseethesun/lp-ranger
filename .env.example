# ══════════════════════════════════════════════════════════════════════════════
# 9mm v3 Position Manager — Configuration
# Copy this file to .env and fill in your values.
# All settings here are read by src/config.js at startup.
# ══════════════════════════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────────────────────────

# HTTP port the dashboard is served on.
# Open http://localhost:PORT in your browser after starting the server.
PORT=5555

# Network interface to bind to.
# '127.0.0.1' = localhost only (default, recommended).
# '0.0.0.0' = all interfaces (accessible from other devices on your network).
HOST=127.0.0.1

# ── Chain ────────────────────────────────────────────────────────────────────
# Which blockchain to connect to. Supported values: pulsechain, pulsechain-testnet.
# Default: pulsechain (mainnet). Testnet uses tPLS for gas.
# CHAIN_NAME=pulsechain

# ── Wallet (required for live bot mode) ───────────────────────────────────────
#
# Two options for providing your signing key:
#
# Option A: raw private key (plaintext hex string, simplest).
PRIVATE_KEY=0xYOUR_WALLET_PRIVATE_KEY
#
# Option B: encrypted wallet (recommended for security).
# Import via the dashboard UI, or from the command line:
#   node scripts/import-wallet.js
# This creates app-config/.wallet.json encrypted with your chosen password.
# On startup, the app prompts for the password (dashboard unlock dialog),
# or reads it from WALLET_PASSWORD below for unattended operation.
#
# WARNING: If you lose your password, the encrypted wallet CANNOT be
# recovered. Keep a secure backup of your private key or seed phrase.
#
# WALLET_PASSWORD — auto-unlock for headless / unattended deployments.
# When set, the app decrypts the wallet AND all API keys at startup
# without prompting. TRADE-OFF: the password lives as plaintext in
# this file. Leave commented out to use the interactive unlock dialog
# instead (password held only in volatile memory, never on disk).
# Run `npm run reset-wallet` to scrub this line + delete the wallet.
#
# WALLET_PASSWORD=

# ── Position Discovery ────────────────────────────────────────────────────────

# For NFT (ERC-721) positions — the token ID shown on scan.9mm.pro.
# Leave blank to enable full wallet enumeration (all NFTs discovered automatically).
POSITION_ID=

# For ERC-20 / PRC-20 position tokens — the contract address.
# Leave blank if your pool uses the standard NFT position model.
ERC20_POSITION_ADDRESS=

# ── Bot Behaviour ─────────────────────────────────────────────────────────────

# Dry-run mode — connects, detects, polls, but never sends transactions.
# Use this first to verify your configuration before risking real funds.
DRY_RUN=false

# PulseChain JSON-RPC endpoint (primary).
# The bot automatically falls back to the official PulseChain RPC if this
# endpoint is unreachable.
RPC_URL=https://rpc-pulsechain.g4mm4.io

# Fallback RPC endpoint — used automatically if RPC_URL is unreachable.
RPC_URL_FALLBACK=https://rpc.pulsechain.com

# Out-of-range threshold: % the price must move beyond the position boundary
# before triggering a rebalance. Example: 10 means the price must be 10% below
# the lower bound or 5% of the range width above the upper bound.
REBALANCE_OOR_THRESHOLD_PCT=5

# Maximum slippage tolerance for rebalance transactions (percent).
SLIPPAGE_PCT=0.75

# Seconds before a pending TX is speed-up-replaced with higher gas.
# PulseChain TXs occasionally sit pending; this auto-bumps the gas price.
TX_SPEEDUP_SEC=120

# How often the bot checks on-chain position status, in seconds.
CHECK_INTERVAL_SEC=60

# Minimum minutes that must elapse between any two rebalances.
# Prevents thrashing during rapid price moves.
MIN_REBALANCE_INTERVAL_MIN=10

# Max rebalances per liquidity pool per 24-hour window.
# Once reached, the bot waits until midnight reset before rebalancing again.
MAX_REBALANCES_PER_DAY=5

# Path for the JSON rebalance event log (relative to project root).
# Default location is inside app-config/ alongside other runtime state.
LOG_FILE=./app-config/rebalance_log.json

# ── Contract Addresses (9mm Pro V3 on PulseChain) ────────────────────────────
# Source: https://github.com/9mm-exchange/deployments/blob/main/pulsechain/v3.json
# IMPORTANT: Verify on scan.9mm.pro before using with real funds.

POSITION_MANAGER=0xCC05bf158202b4F461Ede8843d76dcd7Bbad07f2
FACTORY=0xe50DbDC88E87a2C92984d794bcF3D1d76f619C68
SWAP_ROUTER=0x7bE8fbe502191bBBCb38b02f2d4fA0D628301bEA

