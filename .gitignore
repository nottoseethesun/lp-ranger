# ── Project-specific ─────────────────────────────────────────────────────────

# Claude Code local settings
.claude/

# Environment config (contains secrets)
.env
.env.*
!.env.example

# Per-install operator config + state lives under app-config/.  The
# only two things tracked directly under app-config/ are the two
# subdirectories:
#   - app-defaults-for-user-configurable/  shipped defaults (tracked)
#   - user-configurable/                   operator overrides; CONTENTS
#                                          gitignored so operator data
#                                          survives tarball upgrades.
#                                          README.md is the one tracked
#                                          file inside.
# See the `app-config/` section of server.js for the full layout.
app-config/*
!app-config/app-defaults-for-user-configurable/
!app-config/user-configurable/
app-config/user-configurable/*
!app-config/user-configurable/README.md

# Per-install runtime data lives under app-data/.  Everything in here
# is gitignored except the tracked README.md so the directory ships in
# the release tarball.
app-data/*
!app-data/README.md

# Diagnostic log output (write-only; the app never reads it back).
# Auto-created by src/log-file.js on first --log-file invocation.
# Already covered by the standard `logs` rule in the Node.js section
# below — this comment exists to flag the convention for this project.

# Encrypted private key files (legacy root drops — always gitignore-safe)
*.keyfile.json
keyfile.json
keyfile*.json

# Local temp directory (used by tests)
tmp/

# Check report artifacts (generated by `npm run check`).
# Raw JSON/TAP tool outputs plus summary.txt, tests-summary.txt, report.pdf.
# See the "Check report artifacts" section of server.js for the full layout.
test/report-artifacts/

# Build output (regenerated by npm run build)
public/dist/
public/build-info.js
public/disclosure-content.js
src/build-info.json

# Self-hosted fonts (copied from node_modules by npm run copy-fonts)
public/fonts/

# ── Standard Node.js (github/gitignore) ──────────────────────────────────────

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# Diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage
*.lcov

# nyc test coverage
.nyc_output

# Grunt intermediate storage (https://gruntjs.com/creating-plugins#storing-task-files)
.grunt

# Bower dependency directory (https://bower.io/)
bower_components

# node-waf configuration
.lock-wscript

# Compiled binary addons (https://nodejs.org/api/addons.html)
build/Release

# Dependency directories
node_modules/
jspm_packages/

# Snowpack dependency directory (https://snowpack.dev/)
web_modules/

# TypeScript cache
*.tsbuildinfo

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional stylelint cache
.stylelintcache

# Microbundle cache
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/

# Optional REPL history
.node_repl_history

# Output of 'npm pack'
*.tgz

# Yarn Integrity file
.yarn-integrity

# dotenv environment variable files
# (already covered above in project-specific section)

# parcel-bundler cache (https://parceljs.org/)
.cache
.parcel-cache

# Next.js build output
.next
out

# Nuxt.js build / generate output
.nuxt
dist

# Gatsby files
.cache/
# Comment in the public line in if your project uses Gatsby and not Next.js
# https://nextjs.org/blog/next-9-1#public-directory-support
# public

# vuepress build output
.vuepress/dist

# vuepress v2.x temp and cache directory
.temp
.cache

# Docusaurus cache and generated files
.docusaurus

# Serverless directories
.serverless/

# FuseBox cache
.fusebox/

# DynamoDB Local files
.dynamodb/

# TernJS port file
.tern-port

# Stores VSCode versions used for testing VSCode extensions
.vscode-test

# yarn v2
.yarn/cache
.yarn/unplugged
.yarn/build-state.yml
.yarn/install-state.gz
.pnp.*
